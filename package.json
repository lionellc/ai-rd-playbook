{
  "name": "ai-rd-playbook",
  "version": "0.2.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "gen:meta": "node scripts/generate-meta.mjs",
    "build": "npm run gen:meta && next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build:workers": "npm run build",
    "preview:workers": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "check": "npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "gray-matter": "^4.0.3",
    "next": "16.1.6",
    "nextra": "4.6.1",
    "nextra-theme-docs": "4.6.1",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.25.12",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.1.6",
    "typescript": "^5.9.3",
    "wrangler": "^4.73.0"
  }
}
